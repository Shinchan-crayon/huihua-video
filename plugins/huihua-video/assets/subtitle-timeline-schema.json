{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "audio",
    "audio_sha256",
    "duration",
    "timing_source",
    "text_source",
    "provider",
    "model",
    "voice_id",
    "native_subtitle",
    "items"
  ],
  "properties": {
    "audio": {"type": "string", "minLength": 1},
    "audio_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "duration": {"type": "number", "exclusiveMinimum": 0},
    "timing_source": {"enum": ["minimax_tts", "volcengine_tts"]},
    "text_source": {"const": "approved_narration"},
    "provider": {"enum": ["MiniMax", "Doubao-语音合成-2.0"]},
    "model": {"type": "string", "minLength": 1},
    "voice_id": {"type": "string", "minLength": 1},
    "leading_silence_seconds": {"type": "number", "minimum": 0},
    "native_subtitle": {
      "type": "object",
      "required": ["file", "sha256", "format", "cue_count"],
      "properties": {
        "file": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "format": {"enum": ["json", "srt", "vtt"]},
          "cue_count": {"type": "integer", "minimum": 1},
          "time_offset_seconds": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "sentence_id", "start", "end", "text"],
        "properties": {
          "id": {"type": "string"},
          "sentence_id": {"type": "string"},
          "start": {"type": "number", "minimum": 0},
          "end": {"type": "number", "exclusiveMinimum": 0},
          "text": {"type": "string", "minLength": 1}
        }
      }
    },
    "rhythm_points": {"type": "array"}
  },
  "additionalProperties": false
}
