{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["images"],
  "properties": {
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "scene_id", "file", "role", "width", "height", "fit", "crop_allowed", "prompt"],
        "properties": {
          "id": {"type": "string"},
          "scene_id": {"type": "string"},
          "file": {"type": "string", "minLength": 1},
          "role": {"enum": ["color", "line", "foreground", "midground", "background", "detail"]},
          "width": {"type": "integer", "minimum": 1},
          "height": {"type": "integer", "minimum": 1},
          "fit": {"const": "contain"},
          "crop_allowed": {"const": false},
          "prompt": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
