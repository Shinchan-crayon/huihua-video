{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["scenes"],
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "start", "end", "sentence_ids", "visual_function", "composition", "safe_zones", "beats"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "start": {"type": "number", "minimum": 0},
          "end": {"type": "number", "exclusiveMinimum": 0},
          "sentence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "visual_function": {"type": "string", "minLength": 1},
          "composition": {"type": "string", "minLength": 1},
          "safe_zones": {"type": "array", "minItems": 1},
          "beats": {"type": "array", "minItems": 1}
        }
      }
    }
  }
}
